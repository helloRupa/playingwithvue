{
  "extends": "airbnb-base",
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "parserOptions": {
    "ecmaVersion": 2021
  },
  "rules": {
    "id-length": ["error", { "min": 2 }],
    "no-restricted-syntax": [
      "error",
      { "selector": "ForInStatement", "message": "Use Object.{keys,values,entries} instead." },
      { "selector": "LabeledStatement", "message": "Labels are not allowed." },
      { "selector": "WithStatement", "message": "with is not allowed." }
    ]
  }
}
